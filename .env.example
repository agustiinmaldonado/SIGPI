# Variables de entorno — SIGPI (versión Supabase)
#
# Copiar este archivo como .env.local en el directorio frontend/
# NO commitear .env.local con valores reales.
#
# Obtener estos valores desde:
# Supabase Dashboard → Project Settings → API

# URL del proyecto Supabase
VITE_SUPABASE_URL=

# Clave pública anónima (anon key) — segura para uso en el frontend con RLS activo
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------
# IMPORTANTE: NO incluir service_role_key en el frontend.
# La service_role_key bypasea RLS y es una clave de administración.
# Solo debe usarse en servidores confiables (nunca en código del cliente).
# -----------------------------------------------------------------------

# -----------------------------------------------------------------------
# REFERENCIA HISTÓRICA — Backend Java (NO ACTIVO en esta versión)
# Estas variables ya no se utilizan. Se conservan para documentación.
#
# MYSQL_ROOT_PASSWORD=root
# MYSQL_DATABASE=sigpi_db
# MYSQL_USER=sigpi_user
# MYSQL_PASSWORD=sigpi_pass
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=sigpi_db
# DB_USER=sigpi_user
# DB_PASSWORD=sigpi_pass
# JWT_SECRET=super_secret_key_for_development_must_be_changed_in_prod
# JWT_EXPIRATION_MS=86400000
# -----------------------------------------------------------------------
